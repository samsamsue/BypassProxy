# 复制为 router.conf 后可手动修改；普通用户建议直接运行 ./install.sh 按提示生成。

# LAN 侧设置。
LAN_IF=enp3s0
LAN_NET=192.168.3.0/24
LAN_IP=192.168.3.88

# sing-box 监听端口。
PROXY_PORT=7890
PANEL_PORT=9091
PANEL_SECRET=abc123
ADMIN_PORT=8088

# TUN 设置。
TUN_ENABLE=1
TUN_NAME=sbtun0
TUN_ADDRESS=28.0.0.1/30

# 路由机自身使用的 DNS。手机通常也用这两个 DNS，网关指向 LAN_IP。
DNS1=223.5.5.5
DNS2=119.29.29.29

# 可选：订阅/节点地址。支持 Clash/Mihomo 订阅、v2ray base64 订阅、vmess:// 链接。
# 多个地址用空格分隔。
SUBSCRIBE_URL=''
SUBSCRIBE_URLS=''
SUBSCRIBE_USER_AGENT=clash.meta

# Debian amd64 的 sing-box 安装包地址。需要新版 sing-box 时可以改这里。
SINGBOX_DEB_URL=https://github.com/SagerNet/sing-box/releases/download/v1.13.14/sing-box_1.13.14_linux_amd64.deb

# 可选：安装/更新时下载文件使用的代理。
# 示例：DOWNLOAD_PROXY=http://127.0.0.1:7890
DOWNLOAD_PROXY=''

# 可选：自定义分流规则保存位置。
CUSTOM_RULES_JSON=/etc/bypassproxy/custom-rules.json

# 可选：GitHub 下载加速前缀。
# 示例：GITHUB_DOWNLOAD_PREFIX=https://你的加速地址/
GITHUB_DOWNLOAD_PREFIX=''

# 可选：未指定单个加速前缀时，会按顺序尝试这些 GitHub 下载加速前缀。
GITHUB_DOWNLOAD_PREFIXES='https://gh-proxy.com/ https://ghproxy.net/ https://gh.llkk.cc/'

# MetaCubeXD 静态 Web 面板更新来源。
WEBUI_RELEASE_API=https://api.github.com/repos/MetaCubeX/metacubexd/releases/latest
WEBUI_DOWNLOAD_URL=https://github.com/MetaCubeX/metacubexd/releases/latest/download/compressed-dist.tgz

# 可选：备份同步。支持 WebDAV 和 S3 兼容存储；密码建议在 Web 管理页填写保存。
SYNC_PROVIDER=webdav
WEBDAV_URL=''
WEBDAV_USERNAME=''
WEBDAV_PASSWORD=''
WEBDAV_PATH=BypassProxy

# 可选：S3 兼容对象存储。SYNC_PROVIDER=s3 时使用。
# AWS S3 可留空 S3_ENDPOINT，并把 S3_REGION 填为真实区域；其他兼容服务通常要填写 Endpoint。
S3_ENDPOINT=''
S3_BUCKET=''
S3_REGION=auto
S3_ACCESS_KEY=''
S3_SECRET_KEY=''
S3_PREFIX=BypassProxy
